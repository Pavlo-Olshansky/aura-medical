# =============================================================================
# Production Environment Configuration
# Copy to .env.prod and fill in real values before deploying.
# =============================================================================

# --- Database ---
DATABASE_URL=postgresql+psycopg_async://postgres:CHANGE_ME@db:5432/medtracker
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=medtracker

# --- Application ---
SECRET_KEY=CHANGE_ME_GENERATE_A_LONG_RANDOM_STRING
DOCUMENTS_DIR=/app/documents
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
LOG_LEVEL=WARNING
UVICORN_WORKERS=2

# --- Domain & SSL ---
DOMAIN=aura.example.com
CORS_ORIGINS=["https://aura.example.com"]
SSL_CERT_PATH=/etc/letsencrypt/live/aura.example.com/fullchain.pem
SSL_KEY_PATH=/etc/letsencrypt/live/aura.example.com/privkey.pem

# --- VAPID (push notifications) ---
VAPID_MAILTO=mailto:you@example.com

# --- Weather ---
SKYPULSE_API_KEY=your_key
WEATHER_CITY=Kyiv

# --- Scheduler ---
SCHEDULER_LOCK_KEY=918018
SCHEDULER_LOCK_TIMEOUT=600

# --- Connection Pool ---
POOL_SIZE=5
MAX_OVERFLOW=10
POOL_RECYCLE=3600

# --- Backups ---
BACKUP_SCHEDULE=0 3 * * *
BACKUP_KEEP_LOCAL=30

# --- Offsite Backups (optional — leave empty to skip S3 upload) ---
BACKUP_S3_BUCKET=
BACKUP_S3_ENDPOINT=
BACKUP_S3_PREFIX=medtracker
BACKUP_KEEP_REMOTE=30
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- Telegram Notifications (optional — leave empty to skip) ---
BACKUP_NOTIFY_TELEGRAM_TOKEN=
BACKUP_NOTIFY_TELEGRAM_CHAT_ID=
